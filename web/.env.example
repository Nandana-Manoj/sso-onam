# Copy to web/.env and fill in your Supabase project values.
# The publishable/anon key is safe in the browser; never put the SECRET/service-role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx_or_legacy_anon_jwt

# Set to 'true' only after the MSG91 Send-SMS hook is live (see docs/sms-auth-setup.md).
# Switches auth to phone-keyed accounts (OTP login + password). Default off.
# (Superseded by Firebase phone verification below — leave false.)
VITE_ENABLE_OTP=false

# Firebase phone verification (see docs/phone-verification-setup.md).
# When these are set, registration requires a phone OTP and "Forgot password"
# becomes self-service. Google delivers the SMS, so no MSG91/DLT is needed.
# All four are required to enable the feature. Safe to expose in the browser.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
VITE_FIREBASE_APP_ID=
