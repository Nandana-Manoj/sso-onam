# ── STAGING frontend config ─────────────────────────────────────────────────
# Copy to web/.env.staging (gitignored) and fill in the STAGING Supabase +
# Firebase project values. These are browser-safe (publishable/anon only).
# NEVER put a service-role/secret key in a VITE_ var — it ships to the browser.
#
# This is a SEPARATE Supabase project from production (see docs/release-readiness.md
# §2–3). The whole point is that volunteers test here, never against prod.

VITE_APP_ENV=staging

VITE_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_staging_xxxxx

# Keep OTP off in staging unless you are specifically testing the OTP path.
VITE_ENABLE_OTP=false

# Firebase is only a stateless phone-verification gate (no app data lives in it),
# so REUSE the prod Firebase project here — no separate project needed. Just:
#   1. Add this staging domain to Firebase → Auth → Settings → Authorized domains.
#   2. Configure Firebase "test phone numbers" (Auth → Phone) — canned codes, no
#      SMS sent — so staging testing never hits real phones or the prod SMS quota.
# Then paste the SAME four values as prod below. (Leave blank to disable phone
# verification in staging — registration then uses mobile + password only.)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
VITE_FIREBASE_APP_ID=
