# ── PRODUCTION test-pass frontend config (opt-in, final-pass-only) ─────────
# Copy to web/.env.prod-test (gitignored) and fill in the PROD project's
# browser-safe values (anon key only — never a service-role key here).
#
# Used ONLY by `npm run test:e2e:prod` (Vite --mode prod-test), which points
# the E2E browser run at the real prod site/backend for a final pre-launch
# validation pass against sentinel-tagged data (see ../.env.prod-test and
# web/scripts/{seed,reset}-prod-test.mjs). Never used for normal `npm run dev`.

VITE_APP_ENV=prod-test

VITE_SUPABASE_URL=https://YOUR-PROD-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_prod_xxxxx

VITE_ENABLE_OTP=false

# Same four Firebase values as web/.env — Firebase is shared/stateless across
# environments (see release-staging-strategy). Leave blank to skip phone
# verification during the prod-test E2E run (registration flows aren't part
# of the automated prod-test pass — see the coverage report).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
VITE_FIREBASE_APP_ID=
