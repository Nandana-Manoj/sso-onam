# ── STAGING ops config (seed / reset scripts) ───────────────────────────────
# Copy to .env.staging (gitignored) at the repo root and fill in the STAGING
# Supabase project values. Used ONLY by web/scripts/seed-staging.mjs and
# reset-staging.mjs — never by the browser app.
#
# The SERVICE-ROLE key bypasses RLS and can read/write everything. Treat it like
# a password: it lives only in this local file, never in web/.env, never committed.
# Get both values from the STAGING project: Supabase Dashboard → Project Settings
# → API (Project URL + service_role secret).

SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (staging service_role secret)

# Safety net: paste your PRODUCTION project URL here. The scripts hard-refuse to
# run if SUPABASE_URL matches this, so a copy-paste slip can't seed/wipe prod.
PROD_SUPABASE_URL=https://YOUR-PROD-REF.supabase.co

# Used ONLY by web/tests/integration/*.test.ts and web/tests/e2e/* (via
# npm run test:integration / test:e2e) to sign in as seeded sentinel users and
# exercise real RLS. This is the ANON key, not a secret — same value that ships
# in the public frontend bundle — safe to paste directly in chat if easier than
# editing this file. Get it from: Supabase Dashboard → STAGING project →
# Project Settings → API → anon / public key.
SUPABASE_ANON_KEY=eyJ... (staging anon/public key)
