# ── PRODUCTION test-pass ops config (opt-in, final-pass-only) ───────────────
# Copy to .env.prod-test (gitignored) at the repo root and fill in the PROD
# project's values. Used ONLY by web/scripts/seed-prod-test.mjs and
# reset-prod-test.mjs, and by `npm run test:integration:prod` / `test:e2e:prod`
# — never by the browser app, and never automatically. This is deliberately
# more ceremony than .env.staging: prod-test scripts require THREE separate
# confirmations (EXPECTED_PROD_URL matching exactly, this env var, and a
# distinct --yes-this-is-prod CLI flag) so a copy-paste slip or muscle memory
# from the staging scripts can never fire this against prod by accident.
#
# ALWAYS run the matching reset-prod-test.mjs immediately after any prod-test
# run — never leave sentinel data sitting in production.

SUPABASE_URL=https://YOUR-PROD-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (PROD service_role secret)
SUPABASE_ANON_KEY=eyJ... (PROD anon/public key — not a secret, but needed for the RLS-signed-in-user integration tests)

# Explicit opt-in: must exactly equal SUPABASE_URL above, or every prod-test
# script refuses to run. Retyping it here (separately from SUPABASE_URL) is
# the point — it forces a deliberate second look at the target before writing
# to production.
EXPECTED_PROD_URL=https://YOUR-PROD-REF.supabase.co

# Explicit opt-in #2: must be the literal string "true".
I_UNDERSTAND_THIS_IS_PRODUCTION=true

# Read by web/playwright.config.ts's webServer command so `npm run test:e2e:prod`
# points the BROWSER (not just the Node-side seed/reset scripts) at prod too.
PLAYWRIGHT_VITE_MODE=prod-test
